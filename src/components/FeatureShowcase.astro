---
import PhoneMockup from './ui/PhoneMockup.astro';
import ChatBubble from './ui/ChatBubble.astro';

const features = [
  {
    title: 'Registro de gastos',
    subtitle: 'Tan fácil como enviar un mensaje',
    description: 'Texto, voz o fotos de boletas. Gastify entiende todo y lo clasifica al instante.',
    mockupId: 'expense',
  },
  {
    title: 'Presupuesto mensual',
    subtitle: 'Nunca más te pases del presupuesto',
    description: 'Define tu límite y recibe alertas automáticas. Tu disponible se calcula con ingresos, gastos y ahorros.',
    mockupId: 'budget',
  },
  {
    title: 'Ingresos',
    subtitle: 'Registra todo lo que entra',
    description: 'Sueldo, ventas, freelance o cualquier ingreso. Gastify lo clasifica y lo integra a tu presupuesto automáticamente.',
    mockupId: 'income',
  },
  {
    title: 'Ahorros',
    subtitle: 'Ahorra sin complicaciones',
    description: 'Registra ahorros con un mensaje. Define montos o porcentajes y ve cómo se ajusta tu presupuesto en tiempo real.',
    mockupId: 'savings',
  },
  {
    title: 'Resúmenes con IA',
    subtitle: 'Entiende tus finanzas sin esfuerzo',
    description: 'Resúmenes diarios, semanales y mensuales con análisis inteligente de tus hábitos.',
    mockupId: 'summary',
  },
  {
    title: 'Recordatorios',
    subtitle: 'Nunca más olvides un pago',
    description: 'Crea recordatorios con lenguaje natural. Soporta recurrencia diaria, semanal y mensual.',
    mockupId: 'reminder',
  },
  {
    title: 'Multicuentas',
    subtitle: 'Comparte tus finanzas en equipo',
    description: 'Crea hasta 5 cuentas, invita miembros y lleva las finanzas del hogar, negocio o grupo. Todos ven los movimientos al instante.',
    mockupId: 'multiaccounts',
  },
];
---

<section class="py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center fade-up">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Todo lo que necesitas</h2>
      <p class="mt-4 text-lg text-gray-400">Sin apps que instalar. Sin complicaciones.</p>
    </div>

    <div class="mt-20 flex flex-col gap-32">
      {features.map((feature, i) => (
        <div class:list={['fade-up flex flex-col items-center gap-12 lg:flex-row lg:gap-20', i % 2 === 1 && 'lg:flex-row-reverse']}>
          <!-- Text -->
          <div class="flex-1 text-center lg:text-left">
            <span class="text-sm font-semibold uppercase tracking-wider text-teal">{feature.title}</span>
            <h3 class="mt-3 text-2xl font-bold text-white sm:text-3xl">{feature.subtitle}</h3>
            <p class="mt-4 text-lg text-gray-400">{feature.description}</p>
          </div>

          <!-- Phone mockup -->
          <div class="flex-1">
            {feature.mockupId === 'expense' && (
              <PhoneMockup>
                <ChatBubble sender="user" time="09:15">bencina 30k</ChatBubble>
                <ChatBubble sender="bot" time="09:15">
                  <p class="font-semibold text-teal-light">Gasto registrado</p>
                  <p class="mt-1">🚗 Transporte — $30.000</p>
                </ChatBubble>
                <ChatBubble sender="user" time="09:20">🎤 <span class="italic text-gray-300">Audio: "gaste doce mil en la farmacia"</span></ChatBubble>
                <ChatBubble sender="bot" time="09:20">
                  <p class="font-semibold text-teal-light">Gasto registrado</p>
                  <p class="mt-1">💊 Salud — $12.000</p>
                </ChatBubble>
              </PhoneMockup>
            )}
            {feature.mockupId === 'budget' && (
              <PhoneMockup>
                <ChatBubble sender="user" time="10:00">presupuesto 500000</ChatBubble>
                <ChatBubble sender="bot" time="10:00">
                  <p class="font-semibold text-teal-light">Presupuesto actualizado</p>
                  <p class="mt-1">📊 Tu presupuesto mensual es $500.000</p>
                </ChatBubble>
                <ChatBubble sender="bot" time="18:00">
                  <p class="font-semibold text-yellow-400">⚠️ Alerta de presupuesto</p>
                  <p class="mt-1">Presupuesto: $500.000</p>
                  <p>+ Ingresos: $800.000</p>
                  <p>− Gastos: $420.000</p>
                  <p>− Ahorros: $80.000</p>
                  <p class="mt-2 border-t border-gray-600 pt-2 font-semibold text-teal-light">Disponible: $800.000</p>
                </ChatBubble>
              </PhoneMockup>
            )}
            {feature.mockupId === 'income' && (
              <PhoneMockup>
                <ChatBubble sender="user" time="01/03">recibi mi sueldo 850000</ChatBubble>
                <ChatBubble sender="bot" time="01/03">
                  <p class="font-semibold text-teal-light">Ingreso registrado</p>
                  <p class="mt-1">💰 Salario — $850.000</p>
                </ChatBubble>
                <ChatBubble sender="user" time="10:45">ingreso freelance 120000</ChatBubble>
                <ChatBubble sender="bot" time="10:45">
                  <p class="font-semibold text-teal-light">Ingreso registrado</p>
                  <p class="mt-1">💻 Freelance — $120.000</p>
                  <p class="mt-1 text-[11px] text-gray-400">Ingresos del mes: $970.000</p>
                </ChatBubble>
              </PhoneMockup>
            )}
            {feature.mockupId === 'savings' && (
              <PhoneMockup>
                <ChatBubble sender="user" time="09:00">ahorro 50000 para vacaciones</ChatBubble>
                <ChatBubble sender="bot" time="09:00">
                  <p class="font-semibold text-teal-light">Ahorro registrado</p>
                  <p class="mt-1">🏖️ Vacaciones — $50.000</p>
                </ChatBubble>
                <ChatBubble sender="user" time="09:05">ahorro 10% para fondo de emergencia</ChatBubble>
                <ChatBubble sender="bot" time="09:05">
                  <p class="font-semibold text-teal-light">Ahorro registrado</p>
                  <p class="mt-1">🛡️ Fondo de emergencia — $97.000</p>
                  <p class="mt-1 text-[11px] text-gray-400">Ahorros del mes: $147.000</p>
                </ChatBubble>
              </PhoneMockup>
            )}
            {feature.mockupId === 'summary' && (
              <PhoneMockup>
                <ChatBubble sender="bot" time="21:00">
                  <p class="font-semibold text-teal-light">📋 Resumen del día</p>
                  <p class="mt-2">🚗 Transporte: $6.500</p>
                  <p>🍕 Restaurantes: $8.000</p>
                  <p>🛒 Supermercado: $45.000</p>
                  <p class="mt-2 border-t border-gray-600 pt-2 font-semibold">Total: $59.500</p>
                </ChatBubble>
                <ChatBubble sender="user" time="21:01">en qué más gasto este mes?</ChatBubble>
                <ChatBubble sender="bot" time="21:01">
                  <p>Tu categoría más alta es 🛒 Supermercado con un 45% del total.</p>
                </ChatBubble>
              </PhoneMockup>
            )}
            {feature.mockupId === 'reminder' && (
              <PhoneMockup>
                <ChatBubble sender="user" time="11:00">recordarme pagar internet el 5 de cada mes</ChatBubble>
                <ChatBubble sender="bot" time="11:00">
                  <p class="font-semibold text-teal-light">Recordatorio creado</p>
                  <p class="mt-1">🔔 Pagar internet</p>
                  <p class="text-[11px] text-gray-400">Mensual — día 5 a las 10:00</p>
                </ChatBubble>
                <ChatBubble sender="bot" time="05/03">
                  <p class="font-semibold text-teal-light">⏰ Recordatorio</p>
                  <p class="mt-1">Hoy toca pagar internet. No lo olvides!</p>
                </ChatBubble>
              </PhoneMockup>
            )}
            {feature.mockupId === 'multiaccounts' && (
              <PhoneMockup>
                <ChatBubble sender="user" time="08:30">crear cuenta Hogar</ChatBubble>
                <ChatBubble sender="bot" time="08:30">
                  <p class="font-semibold text-teal-light">Cuenta creada</p>
                  <p class="mt-1">🏠 Hogar — lista para usar</p>
                  <p class="mt-1 text-[11px] text-gray-400">Invita miembros con /invitar</p>
                </ChatBubble>
                <ChatBubble sender="user" time="08:32">cambiar a cuenta Hogar</ChatBubble>
                <ChatBubble sender="bot" time="08:32">
                  <p class="font-semibold text-teal-light">Cuenta activa: Hogar 🏠</p>
                  <p class="mt-1">Ahora tus movimientos se registran en esta cuenta.</p>
                </ChatBubble>
              </PhoneMockup>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
